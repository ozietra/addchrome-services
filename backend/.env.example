# ==== BACKEND ORTAM DEGISKENLERI (ORNEK) ====
# Bu dosyayi .env olarak kopyalayip degerleri doldurun (yerel gelistirme icin).
# Sunucuda (cPanel / Render) bu degerleri panonun arayuzune girin.

# Calisma ortami
NODE_ENV=production

# Sunucu portu (cPanel otomatik atar; yerelde 3000 birakabilirsiniz)
PORT=3000

# MongoDB baglanti adresi — MongoDB Atlas'tan alacaginiz SRV adresi:
# mongodb+srv://KULLANICI:SIFRE@cluster0.xxxxx.mongodb.net/chrome-extensions?retryWrites=true&w=majority
MONGODB_URI=

# JWT imzalama anahtari — UZUN ve RASTGELE olmali (en az 32 karakter).
# Olusturmak icin:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Admin panel girisi — MUTLAKA varsayilanlardan degistirin!
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Fiyat Tarama Microservice (Render.com'da calisan Puppeteer servisi)
# Deploy ettikten sonra Render'in verdigi URL'yi buraya yazin.
# API key'in Render panosundaki SCRAPER_API_KEY ile ayni olmasi gerekir.
SCRAPER_SERVICE_URL=https://addchrome-price-scraper.onrender.com
SCRAPER_API_KEY=

# NOT: AI Listing Writer'in Groq anahtarlari bu backend'de degil, admin panelden
# (Eklentiler sayfasi) veritabanina girilir. Bu backend sadece onlari ai-listing-backend
# servisine sunar. Rastgele, uzun bir deger uretin:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# ai-listing-backend/.env'deki LISTING_CONFIG_SECRET ile BIREBIR AYNI olmali.
LISTING_CONFIG_SECRET=

# CORS icin izinli kaynaklar (virgulle ayrilmis). Ornek:
# https://addchrome.com,https://api.addchrome.com
# Chrome eklentileri (chrome-extension://) zaten otomatik izinli.
ALLOWED_ORIGINS=

# ---- Odeme (PayTR) — premium satisi acana kadar bos birakilabilir ----
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_OK_URL=https://api.addchrome.com/api/payment/success
PAYTR_FAIL_URL=https://api.addchrome.com/api/payment/fail
PAYTR_CALLBACK_URL=https://api.addchrome.com/api/payment/webhook
