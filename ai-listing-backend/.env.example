# ==== AI LISTING BACKEND ORTAM DEGISKENLERI (ORNEK) ====
# Bu dosyayi .env olarak kopyalayip degerleri doldurun.
# Bu servis kendi veritabanina sahip DEGILDIR — auth/abonelik/kullanim kontrolu
# icin mevcut paylasilan chrome-extensions-backend'e (MAIN_BACKEND_URL) HTTP
# ile sorar. Boylece tum eklentiler ayni kullanici tabanini paylasir.

NODE_ENV=production
PORT=4000

# Paylasilan ana backend'in genel API adresi (auth + subscription endpointleri icin)
MAIN_BACKEND_URL=https://addchrome.com/api

# Ana backend'deki LISTING_CONFIG_SECRET ile BIREBIR AYNI olmali. Bununla admin
# panelde girilen Groq anahtarlari GET /listing-config uzerinden cekilir.
LISTING_CONFIG_SECRET=

# Yedek (fallback) Groq anahtarlari — sadece admin panelden hic key girilmemisse
# veya /listing-config'e ulasilamiyorsa kullanilir. console.groq.com — gsk_ ile
# baslar, virgulle ayrilmis, en fazla 20 tane.
# Ornek: GROQ_API_KEYS=gsk_abc123,gsk_def456,gsk_ghi789
GROQ_API_KEYS=
# console.groq.com/docs/models adresinden gecerli model adini kontrol edin.
GROQ_MODEL=llama-3.3-70b-versatile

# CORS icin izinli kaynaklar (virgulle ayrilmis, opsiyonel).
# Chrome eklentileri (chrome-extension://) zaten otomatik izinli.
ALLOWED_ORIGINS=
